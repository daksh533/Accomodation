<%if(success && Array.isArray(success) && success.length){%>
<div class="alert alert-success col-6 offset-3 mt-2 alert-dismissible fade show" role="alert">
    <%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<%}%>

<%if(error && Array.isArray(error) && error.length){%>
  <div class="alert alert-danger col-6 offset-3 mt-2 alert-dismissible fade show" role="alert">
      <%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <%}%>